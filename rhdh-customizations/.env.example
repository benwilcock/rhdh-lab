# ==========================================================================
# RHDH Lab Environment Configuration
# ==========================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Lines marked REQUIRED must be set before starting RHDH.
# Lines marked OPTIONAL have sensible defaults and can be left as-is.
# ==========================================================================

# Database connection (OPTIONAL -- defaults work for local development)
POSTGRES_DB=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Base URL for all requests (OPTIONAL -- override if using a custom domain)
BASE_URL=http://localhost:7007

# App branding (disabled -- using RHDH built-in defaults to avoid deprecated theme conflicts)
# FULL_LOGO_WIDTH=128
# PRIMARY_LIGHT_COLOR=#c9190b
# HEADER_LIGHT_COLOR_1=#c9190b
# HEADER_LIGHT_COLOR_2=#8b0000
# NAV_INDICATOR_LIGHT_COLOR=#c9190b
# PRIMARY_DARK_COLOR=#c9190b
# HEADER_DARK_COLOR_1=#c9190b
# HEADER_DARK_COLOR_2=#8b0000
# NAV_INDICATOR_DARK_COLOR=#c9190b

# GitHub (REQUIRED for GitHub integration)
GITHUB_ORG=your-github-org
GITHUB_HOST_DOMAIN=https://github.com
AUTH_GITHUB_CLIENT_ID=your-github-client-id
AUTH_GITHUB_CLIENT_SECRET=your-github-client-secret

# Feedback & Notifications plugins (OPTIONAL -- only needed if feedback plugin is enabled)
EMAIL_SENDER=you+rhdh-feedback@example.com
EMAIL_USER=you@example.com
EMAIL_PASSWORD=your-email-app-password
EMAIL_HOSTNAME=smtp.gmail.com
EMAIL_PORT=587

# Jenkins plugin (OPTIONAL -- only needed if Jenkins is enabled via compose.override.yaml)
JENKINS_URL=http://jenkins:8080
JENKINS_USERNAME=your-jenkins-user
JENKINS_TOKEN=your-jenkins-api-token

# GitHub Personal Access Token for Scorecard integration (OPTIONAL)
GITHUB_TOKEN=ghp_your-github-pat-here

# Jira Scorecard plugin (OPTIONAL -- only needed if Jira plugin is enabled)
JIRA_BASE_URL=https://your-instance.atlassian.net
JIRA_TOKEN=your-base64-encoded-jira-token

# Configure image to use: default to using the latest stable tag of the community builds,
# which are built for both amd64 and arm64 architectures.
# To use bleeding edge :next images or commercially supported images, see README.md for details.
# RHDH_IMAGE=quay.io/rhdh-community/rhdh:1.9

# Default plugin catalog index image (requires RHDH 1.9+)
CATALOG_INDEX_IMAGE=quay.io/rhdh/plugin-catalog-index:1.9

# Path where extensions catalog entities are extracted from the catalog index image (requires RHDH 1.9+)
CATALOG_ENTITIES_EXTRACT_DIR=/extensions

# Node environment for extensions plugin installation
NODE_ENV=development

# Disable TLS certificate validation (development only)
NODE_TLS_REJECT_UNAUTHORIZED=0

# Telemetry (OPTIONAL)
SEGMENT_WRITE_KEY=
SEGMENT_TEST_MODE=true

# Backstage log level
#LOG_LEVEL=debug

# Logs from global-agent to inspect the 'node-fetch' behavior with proxy settings
#ROARR_LOG=true

# Logs from fetch (useful to inspect 'fetch' behavior with proxy settings handled by 'undici')
#NODE_DEBUG=fetch

# NO_PROXY will take effect only if HTTP(S)_PROXY env vars are set.
# See the compose-with-corporate-proxy.yaml file.
#NO_PROXY=localhost,127.0.0.1

# ==============================================================================
# Developer Lightspeed Configuration
# ==============================================================================
# For detailed documentation, see: developer-lightspeed/README.md
# Note: Ollama is pre-configured by default -- no setup needed.
# External providers require configuration below.

# ------------------------------------------------------------------------------
# Ollama Provider Configuration (Default -- Pre-configured)
# ------------------------------------------------------------------------------
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:1b
# Mount local models directory to persist models across volume removals
# Set this to your local Ollama models path (e.g. ~/.ollama)
OLLAMA_MODELS_PATH=

# ------------------------------------------------------------------------------
# External Provider Enablement
# ------------------------------------------------------------------------------
# Set ONE to 'true' if using external provider instead of Ollama
# ENABLE_VLLM=
# ENABLE_OPENAI=
# ENABLE_VERTEX_AI=

# ------------------------------------------------------------------------------
# vLLM Provider Configuration
# ------------------------------------------------------------------------------
# Required if ENABLE_VLLM=true. Must end with /v1
VLLM_URL=
VLLM_API_KEY=
# VLLM_MAX_TOKENS=4096
# VLLM_TLS_VERIFY=true

# ------------------------------------------------------------------------------
# OpenAI Provider Configuration
# ------------------------------------------------------------------------------
# Required if ENABLE_OPENAI=true. Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ------------------------------------------------------------------------------
# Vertex AI Provider Configuration (Experimental)
# ------------------------------------------------------------------------------
# Required if ENABLE_VERTEX_AI=true
VERTEX_AI_CREDENTIALS_PATH=
VERTEX_AI_PROJECT=
# VERTEX_AI_LOCATION=us-central1

# ------------------------------------------------------------------------------
# Llama Guard Settings
# ------------------------------------------------------------------------------
SAFETY_MODEL=
SAFETY_URL=
SAFETY_API_KEY=
